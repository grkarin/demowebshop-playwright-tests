# Optional credentials for the Demo Web Shop.
#
# The public Demo Web Shop ships with no built-in account, so the tests that
# require a real login (the "valid login" case and the "cart persists after
# login" case) read credentials from these variables and skip themselves when
# the variables are not set. Register an account at
# https://demowebshop.tricentis.com/register and copy this file to `.env`
# (or export the variables in your shell) to run those tests.
#
# LOG_LEVEL controls logger verbosity: debug | info | warn | error (default: info).

TEST_EMAIL=
TEST_PASSWORD=
# LOG_LEVEL=info